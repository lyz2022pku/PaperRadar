# ============================================================
#  PaperRadar 配置文件模板
#  使用方法：复制为 config.yaml，填入真实的 Key 和密码
#  cp config/config.yaml.example config/config.yaml
# ============================================================

# --- AI 分析 API（兼容 OpenAI 接口格式）---
# 示例：Kimi / DeepSeek / 其他兼容 OpenAI 的模型均可
kimi:
  api_key: "sk-your-api-key-here"
  model: "your-model-name"          # 例如 kimi-k2-0905-preview、deepseek-chat
  max_tokens: 1500

# --- 邮件配置 ---
# 支持任意 SMTP 服务商，以下为常见示例：
#   QQ 邮箱:   smtp.qq.com     端口 465  (需开启SMTP服务，使用授权码)
#   Gmail:     smtp.gmail.com  端口 587  (需开启两步验证，使用应用密码)
#   163 邮箱:  smtp.163.com    端口 465
email:
  smtp_server: "smtp.gmail.com"
  smtp_port: 587
  sender: "your-email@gmail.com"
  password: "your-app-password"     # 邮箱授权码/应用密码，非登录密码
  recipient: "recipient@example.com"
  subject_prefix: "📡 PaperRadar"

# --- arXiv 订阅类别 ---
# 完整类别列表见 https://arxiv.org/category_taxonomy
arxiv:
  categories:
    - "cs.LG"           # 机器学习
    - "cs.CV"           # 计算机视觉
    - "cs.AR"           # 硬件架构
  max_results_per_category: 50

# --- Semantic Scholar 目标期刊/会议 ---
# 可选，填写你关注的期刊或会议全名
semantic_scholar:
  enabled: true
  api_key: "your-semantic-scholar-api-key"   # 可留空，有填请求量更大
  target_venues:
    - "Nature"
    - "Science"
    - "NeurIPS"
    - "ICML"
  max_results: 50

# --- 关键词过滤（两级）---
# core: 核心关键词，命中即高度相关，用于 arXiv 查询 + 期刊粗筛
# broad: 扩展关键词，仅用于期刊粗筛，A 分上限 3 分
keywords:
  core:
    - "your core keyword 1"
    - "your core keyword 2"

  broad:
    - "your broad keyword 1"
    - "your broad keyword 2"

# --- 运行设置 ---
settings:
  # 时区：使用 IANA 时区名称
  # 常用示例：Asia/Shanghai（北京时间）、Europe/London（伦敦时间）、America/New_York
  # 完整列表见 https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
  timezone: "Asia/Shanghai"

  # 每天几点运行（上方时区的本地时间，24小时制）
  schedule_hour: 8
  schedule_minute: 0

  # 每封邮件最多推送多少篇
  max_papers_per_email: 30

  # 日志保留天数
  log_retention_days: 30
